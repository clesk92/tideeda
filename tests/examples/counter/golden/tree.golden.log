design work@counter
  module counter #(
    parameter WIDTH = 8,
  ) (
    input wire clk,
    input wire rst_n,
    input wire enable,
    output wire count,
  );
    wire  clk;
    wire  rst_n;
    wire  enable;
    wire  count;
    wire  next_count;
    wire  carry;
    assign next_count = count + 1'b1;
    assign carry = &count;
    always @((posedge clk) or (negedge rst_n)) begin
      begin
        if (!rst_n) begin
          begin
            count <= 0;
          end
          if (enable) begin
            begin
              count <= next_count;
            end
          end
      end
    end
  endmodule
  
