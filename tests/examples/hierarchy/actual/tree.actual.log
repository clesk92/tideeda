design work@hierarchy_top
  module hierarchy_top #(
  ) (
    input wire clk,
    input wire rst_n,
    output wire data_out,
  );
    wire  clk;
    wire  rst_n;
    wire  data_out;
    wire  internal_data;
    wire  clk;
    wire  rst_n;
    wire  data_in;
    wire  data_out;
    assign internal_data = 8'hAB;
    sub_module u_sub (
      .clk(clk),
      .rst_n(rst_n),
      .data_in(internal_data),
      .data_out(data_out)
    );
  endmodule
  
  module sub_module #(
  ) (
    input wire clk,
    input wire rst_n,
    input wire data_in,
    output wire data_out,
  );
    wire  clk;
    wire  rst_n;
    wire  data_in;
    wire  data_out;
    always @((posedge clk) or (negedge rst_n)) begin
      begin
        if (!rst_n) begin
          begin
            data_out <= 8'h00;
          end
          begin
            data_out <= data_in;
          end
      end
    end
  endmodule
  
